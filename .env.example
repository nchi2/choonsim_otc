# ──────────────────────────────────────────────────────────────
# Database — Neon (PostgreSQL)
# ──────────────────────────────────────────────────────────────
# Neon 프로젝트 생성 후 "Connection string"을 그대로 붙여넣는다.
#   1) https://neon.tech 에서 프로젝트 생성 (무료 티어)
#   2) Dashboard → Connection Details → 연결 문자열 복사
#   3) 아래 두 변수에 입력 (반드시 sslmode=require 포함)
#
# DATABASE_URL : 런타임용. Neon 풀러(pooled, -pooler 호스트) 연결 문자열.
#                서버리스에서 연결 수를 절약하기 위해 PgBouncer 풀러를 사용한다.
# DIRECT_URL   : 마이그레이션/스키마 작업용. 풀러를 거치지 않는 직접 연결.
#
# 예: postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=
# 예: postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=

# ──────────────────────────────────────────────────────────────
# Admin (관리자 콘솔 /admin)
# ──────────────────────────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
# 세션 쿠키 서명용 시크릿(랜덤 문자열, 최소 32자 권장).
# 생성 예: `openssl rand -base64 48`
SESSION_SECRET=

# 예상 단가 마진율(서버 전용, 클라이언트로 노출 금지). 미설정 시 0.01(=1%).
MARGIN_RATE=0.01

# ──────────────────────────────────────────────────────────────
# Google / Analytics
# ──────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=
