# ──────────────────────────────────────────────────────────────
# Database — Neon (PostgreSQL)
# ──────────────────────────────────────────────────────────────
# Neon 프로젝트 생성 후 "Connection string"을 그대로 붙여넣는다.
#   1) https://neon.tech 에서 프로젝트 생성 (무료 티어)
#   2) Dashboard → Connection Details → "Prisma" 탭의 URL 복사
#   3) 아래 DATABASE_URL 에 입력 (반드시 sslmode=require 포함)
# 예: postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ──────────────────────────────────────────────────────────────
# Admin (관리자 콘솔 /admin)
# ──────────────────────────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=
# 세션 쿠키 서명용 시크릿(랜덤 문자열, 최소 32자 권장).
# 생성 예: `openssl rand -base64 48`
SESSION_SECRET=

# 예상 단가 마진율(서버 전용, 클라이언트로 노출 금지). 미설정 시 0.01(=1%).
MARGIN_RATE=0.01

# ──────────────────────────────────────────────────────────────
# Google / Analytics
# ──────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=
