// Prisma schema — Neon(Postgres)
// 10모의 기적 신청을 우선 활성화하되, 추후 OTC(매수/매도, 코인/고액권)까지
// 확장 가능한 골격으로 설계. 자세한 내용은 README / .env.example 참고.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderKind {
  MIRACLE10
  OTC
}

enum OrderSide {
  BUY
  SELL
}

enum AssetType {
  COIN
  PAPER
}

enum AssetSymbol {
  BMB
  BTC
  SBMB
}

enum SettleMethod {
  KRW_TRANSFER
  KRW_CASH
  COIN_SWAP
  UNDECIDED
}

enum OrderStatus {
  PENDING
  CONTACTED
  VERIFIED
  COMPLETED
  CANCELED
}

// ── 교육 플랫폼 enums ──
// 신규 테이블이라 기존 데이터 제약이 없어 String+lib 검증 대신 enum 사용(DB 무결성 + Prisma 타입).
// 값 추가는 add-only 마이그레이션으로 처리 가능.

enum EducationCategory {
  LECTURE
  WORKSHOP
  EVENT
}

enum EducationMode {
  OFFLINE
  ONLINE
  HYBRID
}

// 개설 신청 승인 워크플로우 — 승인(APPROVED) + isPublished=true 여야 공개 노출.
enum EducationEventStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventApplicationStatus {
  APPLIED
  CANCELED
}

// 어드민 콘솔 운영자 계정. 비밀번호는 bcrypt 해시로만 저장(평문 금지).
model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  displayName  String
  role         String   @default("operator")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 프로필 — email은 신청 알림 수신자 소스로도 사용
  email String?
  phone String?

  // 정산·급여용 계좌 — ★본인 전용. profile API(세션 uid) 외 어떤 조회/목록에도 노출 금지.
  bankName          String?
  bankAccountNo     String?
  bankAccountHolder String?

  // 신청 알림 수신 종류 선택 — default true(기존 동작=전원 수신 유지).
  alertMiracle10 Boolean @default(true)
  alertOtc       Boolean @default(true)
  alertEducation Boolean @default(true)

  // 관리 스코프 — 운영자별 OTC/교육 관리 영역 분리 (default true = 기존 전원 전권 유지)
  manageOtc       Boolean @default(true)
  manageEducation Boolean @default(true)

  workSlots      WorkSlot[]
  assignedOrders OtcOrder[] @relation("OrderAssignedAdmin")
  walletLedgers  PaperWalletLedger[] @relation("WalletLedgerAdmin")
  comments       OrderComment[] @relation("CommentAuthor")
  commentReads   CommentReadState[] @relation("CommentReader")
}

// 사무실 — enum 대신 테이블(지점 추가·활성화 관리).
model Office {
  id        Int      @id @default(autoincrement())
  code      String   @unique // "GANGNAM", "SEONGSU" …
  name      String // "강남 사무실"
  address   String?
  isActive  Boolean  @default(true) // 손님 노출 여부
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workSlots WorkSlot[]
  orders    OtcOrder[]
  otcRequests OtcRequest[]
  educationEvents EducationEvent[]
  educationSlots  EducationSlot[]
}

// 운영자 근무 가능 슬롯 — 30분 단위, KST date/startTime.
model WorkSlot {
  id          Int       @id @default(autoincrement())
  adminUserId Int
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
  officeId    Int
  office      Office    @relation(fields: [officeId], references: [id])
  date        String // "YYYY-MM-DD" (KST)
  startTime   String // "HH:MM" 30분 단위 시작
  createdAt   DateTime  @default(now())

  @@unique([adminUserId, officeId, date, startTime])
  @@index([officeId, date])
  @@index([date, startTime])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  // 연락처(카카오톡 ID 또는 전화번호) — upsert 기준 키
  contact   String   @unique
  createdAt DateTime @default(now())
  // 면대면 인증 완료 시각 (null이면 미인증)
  verifiedAt DateTime?

  applications OtcOrder[]
}

model OtcOrder {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kind OrderKind // 이번엔 MIRACLE10만 생성
  side OrderSide // 10모는 항상 BUY

  assetType    AssetType // COIN | PAPER
  asset        AssetSymbol? // 코인일 때 (BMB/BTC/SBMB)
  denomination Int? // 고액권 단위 10|50|100|200 (PAPER일 때)

  // 고액권용 — 지금은 미사용
  interest Decimal? @db.Decimal(18, 4)
  premium  Decimal? @db.Decimal(18, 4)

  settle   SettleMethod @default(UNDECIDED)
  quantity Int // 10모 단위 수량(모 수)

  // OTC용 — 지금은 미사용
  desiredPrice Decimal? @db.Decimal(18, 2)

  status OrderStatus @default(PENDING)

  // 10모 폼 필드
  contactTimePref String?
  visitType       String?
  visitDate       String?
  visitTimeSlot   String?

  // 예약 연결 — 기존 visitDate/visitTimeSlot(1시간)과 공존, 신규는 reservedStart(30분).
  officeId            Int?
  office              Office?    @relation(fields: [officeId], references: [id])
  reservedStart       String? // "HH:MM" 확정 시작(30분 슬롯)
  assignedAdminUserId Int?
  assignedAdminUser   AdminUser? @relation("OrderAssignedAdmin", fields: [assignedAdminUserId], references: [id])

  // 사전파악 답 (yes/no/unsure 등)
  needUsdt     String?
  needBmb      String?
  needFaceAuth String?

  isSbmbMember Boolean @default(false)
  memo         String?

  // 테스트 데이터 — 목록·집계·배지·공개 정원(taken)에서 기본 제외 (?includeTest=1)
  isTest Boolean @default(false)

  // 손님이 이미 보유한 종이지갑 장수 (연락 단계 확인) — 준비 장수 = ceil(수량/10) − 보유
  ownedPaperWalletCount Int?

  // 거래 기록 (운영자 작업 화면, 전부 nullable — 기존 데이터 안전)
  p2pExperienceConfirmed Boolean? // 일정 확정 시 "P2P 거래 앱 판매 경험 확인" 체크 여부
  dealQuantity           Int? // 실제 거래 수량 (기본 = 신청 수량)
  dealUnitPriceKrw       Decimal? @db.Decimal(18, 2) // 단가(원) — 계산 결과 기입 후 흥정 반영 수정 가능
  dealUnitPriceUsdt      Decimal? @db.Decimal(18, 6) // 단가(USDT)
  dealCoinTotalKrw       Decimal? @db.Decimal(18, 2) // 코인 총액(원) = 수량 × 단가
  paperWalletCount       Int? // 종이지갑 장수 (기본 = 수량/10)
  paperWalletKrw         Decimal? @db.Decimal(18, 2) // 종이지갑 가격(원) = 장수 × 20 USDT × 환율
  dealTotalKrw           Decimal? @db.Decimal(18, 2) // 총 가격(원) = 코인 총액 + 지갑 가격
  // 수령 지갑 목록 — [{address: string, isOurs: boolean}] (isOurs=우리 종이지갑 → 재고 불출 대상)
  receiveWallets Json @default("[]")

  agreePrivacy Boolean @default(false)
  agreeRisk    Boolean @default(false)
  agreeP2p     Boolean @default(false)

  // 최종 수정자 추적 — 어드민이 상태/내용 변경 시 서버 세션 기준으로 기록.
  lastEditedBy     String? // 수정한 운영자 username(adminUserId)
  lastEditedByName String? // 표시용 이름 스냅샷
  lastEditedAt     DateTime?

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  walletLedgers PaperWalletLedger[] @relation("WalletLedgerOrder")

  @@index([status])
  @@index([kind, status])
  @@index([createdAt])
  @@index([kind])
  @@index([customerId])
  @@index([visitDate])
  @@index([reservedStart])
  @@index([isTest])
}

// 종이지갑(EVM 지갑) 재고 원장 — 입고(IN)/불출(OUT) 행 누적, 재고 = IN 합 − OUT 합.
// type은 String("IN"|"OUT") — API에서 검증 (OtcRequest.status와 같은 패턴).
model PaperWalletLedger {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  type      String // "IN" 입고 | "OUT" 불출 | "ORDER" 발주(입고 예정)
  count     Int // 장수 — 항상 양수, 부호는 type으로 해석
  entryDate String // 실물 입출고(발주) 날짜 YYYY-MM-DD (KST)
  memo      String?

  // ORDER 전용 — 중복 발주 방지용 기록. ★재고(stock=IN−OUT) 계산에 절대 미포함.
  status         String? // ORDER: "PENDING" | "RECEIVED" | "CANCELED"
  expectedDate   DateTime? // 예상 도착일
  linkedLedgerId Int? // 입고 확정 시 생성된 IN 원장 id

  // IN 전용 — 입고 시 스캔한 지갑 주소 배열 ["0x...", ...] (개별 지갑 엔티티는 만들지 않음)
  walletAddresses Json?

  // 등록자/담당 운영자 — 계정 삭제돼도 원장 보존(SetNull + 이름 스냅샷)
  adminUserId Int?
  adminUser   AdminUser? @relation("WalletLedgerAdmin", fields: [adminUserId], references: [id])
  adminName   String

  // 불출 — 수령 신청건(10모) 연결(선택) + 수령자 이름 스냅샷
  orderId      Int?
  order        OtcOrder? @relation("WalletLedgerOrder", fields: [orderId], references: [id])
  receiverName String?

  @@index([type])
  @@index([type, status])
  @@index([entryDate])
  @@index([orderId])
}

// BMB 매수/판매 OTC 신청 — 10모 OtcOrder와 독립.
model OtcRequest {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  side      String // "BUY" | "SELL"
  name      String
  contact   String
  quantity  Int
  desiredPrice Int? // 희망 가격(원)

  receiveAddress String? // 매수 — 받을 모빅 공개주소
  visitDate      String? // 매수 — 방문 희망일 KST
  reservedStart  String? // 매수 — 방문 시간
  officeId       Int?
  office         Office? @relation(fields: [officeId], references: [id])

  senderAddress String? // 매도 — 판매자 지갑
  bankInfo      String? // 매도 — 원화 입금 계좌 (통문자열, 레거시)
  sellerBankName      String? // 판매자 계좌 — 은행명
  sellerAccountNo     String? // 판매자 계좌 — 계좌번호
  sellerAccountHolder String? // 판매자 계좌 — 예금주

  customerBankInfo String? // 운영자 등록 — 매수자 계좌 (통문자열, 레거시)
  buyerBankName       String? // 매수자 계좌 — 은행명 (운영자 등록용)
  buyerAccountNo      String? // 매수자 계좌 — 계좌번호
  buyerAccountHolder  String? // 매수자 계좌 — 예금주
  memo           String?
  // 값은 lib/otc-request-status.ts에서 검증 (String 유지 — 기존 데이터 안전)
  status         String   @default("PENDING")

  // 운영자 작업 기록 — 10모 OtcOrder와 동일 패턴
  adminMemo        String? // 운영자 메모 (손님 제출 memo와 분리)
  lastEditedBy     String?
  lastEditedByName String?
  lastEditedAt     DateTime?

  // 테스트 데이터 — 목록·집계에서 기본 제외 (?includeTest=1)
  isTest Boolean @default(false)

  @@index([status])
  @@index([createdAt])
  @@index([side])
  @@index([isTest])
}

// 신청 건 운영자 코멘트 — 10모(OtcOrder)·OTC(OtcRequest) 공용, targetType+targetId 참조.
// 신규 테이블(기존 데이터 영향 없음). 작성자 삭제 시 SetNull + 이름 스냅샷 보존.
model OrderComment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targetType String // "MIRACLE10" | "OTC_REQUEST" — lib/order-comments.ts에서 검증
  targetId   Int

  authorId   Int?
  author     AdminUser? @relation("CommentAuthor", fields: [authorId], references: [id])
  authorName String // 표시 스냅샷

  body     String
  editedAt DateTime? // 수정된 코멘트 표시용

  @@index([targetType, targetId])
}

// 운영자×신청건 마지막 읽은 시각 — 안읽음 배지 계산용.
model CommentReadState {
  id          Int       @id @default(autoincrement())
  adminUserId Int
  adminUser   AdminUser @relation("CommentReader", fields: [adminUserId], references: [id], onDelete: Cascade)
  targetType  String
  targetId    Int
  lastReadAt  DateTime

  @@unique([adminUserId, targetType, targetId])
}

// ─────────────────────────────────────────────
// 교육 플랫폼 (2026-07 신설) — 행사·회차·수강신청·교육 슬롯.
// OTC(WorkSlot/OtcOrder)와 자원 공유 없음. 코멘트는 OrderComment targetType="EDUCATION_EVENT" 재사용.
// ─────────────────────────────────────────────

// 교육 행사(강의·워크숍·이벤트) — 개설 신청(PENDING) → 승인/반려. 승인+isPublished 시 공개 노출.
model EducationEvent {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title    String
  slug     String            @unique
  category EducationCategory

  posterUrl      String?
  descriptionMd  String? // 소개 (markdown)
  instructorName String?
  instructorBio  String?

  // 장소 — 회관(Office) 매칭 또는 커스텀 텍스트 (둘 다 null 가능 = 장소 미정)
  officeId       Int?
  office         Office? @relation(fields: [officeId], references: [id])
  customLocation String?

  mode      EducationMode
  streamUrl String? // ONLINE/HYBRID 스트림 링크

  capacity Int? // null = 무제한. 정원 검사는 신청 API 트랜잭션에서 count로 원자 처리.
  feeKrw   Int  @default(0) // 0 = 무료

  // 입금 안내 (유료 행사) — OtcRequest sellerBank* 네이밍 관례와 정렬
  depositBankName      String?
  depositAccountNo     String?
  depositAccountHolder String?

  // 상세 안내 텍스트
  eligibility  String? // 참여 조건
  preparation  String? // 준비물
  reward       String?
  refundPolicy String?
  notice       String? // 유의사항

  applyDeadline DateTime? // null = 마감 미지정

  // 개설 승인 워크플로우 — 반려 시 사유 필수(API에서 강제)
  status       EducationEventStatus @default(PENDING)
  rejectReason String?
  isPublished  Boolean              @default(false)
  isFeatured   Boolean              @default(false) // 메인 캐러셀 노출

  // 개설 신청자(무계정) 스냅샷
  hostName    String?
  hostContact String?
  hostEmail   String?

  // 교육자(회원) 개설 연결 자리 — B-3에서 사용, 지금은 필드만
  hostMemberId String?
  hostMember   Member? @relation(fields: [hostMemberId], references: [id], onDelete: SetNull)

  isTest Boolean @default(false)

  lastEditedBy     String?
  lastEditedByName String?
  lastEditedAt     DateTime?

  sessions     EventSession[]
  applications EventApplication[]

  @@index([status])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([isTest])
}

// 행사 회차(세션) — 시리즈 = 세션 N개. KST date/startTime 문자열 (WorkSlot과 동일 표기).
model EventSession {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  eventId Int
  event   EducationEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  date      String // "YYYY-MM-DD" (KST)
  startTime String // "HH:MM"
  endTime   String // "HH:MM"

  applications EventApplication[]

  @@index([eventId])
  @@index([date, startTime])
}

// 수강 신청 — 비로그인(이름·연락처 스냅샷). 행사 삭제 시 함께 삭제, 세션 삭제 시 신청은 보존(SetNull).
model EventApplication {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  eventId Int
  event   EducationEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  sessionId Int?
  session   EventSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  name          String
  contact       String
  email         String? // 선택 — 전일 리마인더 수신용(없으면 리마인더 스킵)

  // 로그인 상태 신청이면 회원 연결(B-1). 비로그인 신청은 null — 기존 동작 유지.
  memberId String?
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  depositorName String? // 입금자명
  question      String? // 사전 질문
  agreePrivacy  Boolean @default(false)

  status          EventApplicationStatus @default(APPLIED)
  paidConfirmedAt DateTime? // 입금 확인 시각
  attendedAt      DateTime? // 출석 체크 시각

  isTest Boolean @default(false)

  // [eventId, status]가 정원 카운트 쿼리(count where eventId+APPLIED)와 eventId 단독 조회를 함께 커버
  @@index([eventId, status])
  @@index([sessionId])
  @@index([isTest])
}

// ─────────────────────────────────────────────
// 회원 (B-1) — 참여자·교육자 공용. ★AdminUser(운영자)와 완전 분리(테이블·쿠키·세션 sub).
// 가입 시 전원 참여자, 교육자는 educatorStatus 신청→승인(B-3).
// ─────────────────────────────────────────────

model Member {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email        String    @unique
  passwordHash String? // 구글 전용 계정은 null (평문 저장 금지)
  name         String
  // 자체가입은 API에서 필수 강제. 구글 가입은 전화가 없어 null 허용 — 마이페이지에서 보완(B-2).
  phone        String?
  emailVerifiedAt DateTime?

  provider          String  @default("local") // "local" | "google" (가입 경로)
  providerAccountId String? // 구글 sub — 이메일 일치 시 기존 계정에 연결

  // 교육자 승인 워크플로우(B-3에서 사용) — NONE | PENDING | APPROVED | REJECTED
  educatorStatus       String    @default("NONE")
  // 신청 시 소개·활동 계획(자유 텍스트) — 어드민 승인 판단 근거. 재신청 시 갱신. (12A)
  educatorIntro        String?   @db.Text
  educatorRejectReason String?
  educatorAppliedAt    DateTime?
  educatorApprovedAt   DateTime?

  status String @default("ACTIVE") // ACTIVE | SUSPENDED

  verificationTokens EmailVerificationToken[]
  applications       EventApplication[]
  hostedEvents       EducationEvent[]

  @@index([provider, providerAccountId])
}

// 이메일 인증 토큰 — 원문 저장 금지, sha256 해시만. 만료·1회 사용.
model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  tokenHash String // sha256(token) hex
  expiresAt DateTime
  usedAt    DateTime?

  @@index([memberId])
  @@index([tokenHash])
}

// 교육용 회관 슬롯 — 기존 WorkSlot(OTC 근무)과 별개 테이블, 자원 공유 없음.
model EducationSlot {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  officeId Int
  office   Office @relation(fields: [officeId], references: [id])

  date      String // "YYYY-MM-DD" (KST)
  startTime String // "HH:MM"
  endTime   String // "HH:MM"
  memo      String?

  @@index([officeId, date])
}
